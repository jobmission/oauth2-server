<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="third_pargy_entity_create" author="xyz">
        <preConditions>
            <not>
                <tableExists tableName="third_pargy_entity"/>
            </not>
        </preConditions>
        <createTable tableName="third_pargy_entity" remarks="third_pargy_entity">
            <column name="id" type="BIGINT" remarks="id" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_third_pargy_entity_id"/>
            </column>
            <column name="third_party" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="third_party_account_id" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="nick_name" type="varchar(255)"/>
            <column name="avatar_url" type="varchar(255)"/>
            <column name="account_open_code" type="varchar(255)"/>
            <column name="version" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="record_status" type="int" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="sort_priority" type="int" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="datetime" remarks="创建时间" defaultValueComputed="${timeDefaultValue}"/>
            <column name="last_modified" type="datetime" remarks="更新时间"/>
            <column name="remarks" type="varchar(1000)" remarks="备注"/>
        </createTable>
        <createIndex indexName="uc_tpe_third_party_third_party_account_id" tableName="third_pargy_entity" unique="true">
            <column name="third_party"/>
            <column name="third_party_account_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
