<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="oauth_client_entity_create" author="xyz">
        <preConditions>
            <not>
                <tableExists tableName="oauth_client_entity"/>
            </not>
        </preConditions>
        <createTable tableName="oauth_client_entity" remarks="oauth_client_entity">
            <column name="id" type="BIGINT" remarks="id" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_oauth_client_entity_id"/>
            </column>
            <column name="client_id" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="client_secret" type="varchar(255)"/>
            <column name="client_authentication_methods" type="varchar(255)"/>
            <column name="application_name" type="varchar(255)"/>
            <column name="additional_information" type="varchar(255)"/>
            <column name="authorities" type="varchar(255)"/>
            <column name="authorized_grant_types" type="varchar(255)"/>
            <column name="auto_approve" type="varchar(255)"/>
            <column name="resource_ids" type="varchar(255)"/>
            <column name="scope" type="varchar(255)"/>
            <column name="web_server_redirect_uri" type="varchar(255)"/>
            <column name="access_token_validity" type="INT"/>
            <column name="refresh_token_validity" type="INT"/>
            <column name="expiration_date" type="datetime(6)"/>
            <column name="failure_count" type="INT"/>
            <column name="failure_time" type="date"/>
            <column name="version" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="record_status" type="int" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="sort_priority" type="int" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="datetime" remarks="创建时间" defaultValueComputed="${timeDefaultValue}"/>
            <column name="last_modified" type="datetime" remarks="更新时间"/>
            <column name="remarks" type="varchar(1000)" remarks="备注"/>
        </createTable>
        <createIndex indexName="uc_oce_client_id" tableName="oauth_client_entity" unique="true">
            <column name="client_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
